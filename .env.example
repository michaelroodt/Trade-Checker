# KuCoin Futures API Credentials
# Get these from: https://www.kucoin.com/account/api
# Required permissions: General + Trade
KUCOIN_API_KEY=your_api_key_here
KUCOIN_API_SECRET=your_api_secret_here
KUCOIN_API_PASSPHRASE=your_passphrase_here

# MCP Authentication Key (set your own secure random string)
# Used to authenticate requests to this MCP server
MCP_AUTH_KEY=your_secure_random_key_here
